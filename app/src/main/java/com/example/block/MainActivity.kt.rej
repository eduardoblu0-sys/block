+
+private fun hasReadCallLogPermission(context: Context): Boolean {
+    return ContextCompat.checkSelfPermission(
+        context,
+        Manifest.permission.READ_CALL_LOG
+    ) == PackageManager.PERMISSION_GRANTED
+}
